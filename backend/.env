# ── Server Configuration ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/multilingual_chat

# ── JWT Authentication ───────────────────────────────────────────────────────
# Leave as default for dev mode (raw userId passthrough)
# Set a strong secret in production for real JWT verification
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRE=30d

# ── TURN Server (for reliable WebRTC behind NATs) ────────────────────────────
# You can get free TURN servers from https://www.metered.ca/tools/openrelay/
TURN_URL=turn:openrelay.metered.ca:443
TURN_USERNAME=openrelayproject
TURN_CREDENTIAL=openrelayproject

# ── Supabase (optional, for message persistence) ─────────────────────────────
